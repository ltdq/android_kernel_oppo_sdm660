		qcom,eeprom-src = <&eeprom2 &eeprom3>;
		cam_vio-supply = <&pm660_l11>;
		cam_vana-supply = <&pm660l_bob>;
		cam_vdig-supply = <&pm660_s5>;
		qcom,cam-vreg-name = "cam_vio", "cam_vana", "cam_vdig";
		qcom,cam-vreg-min-voltage = <1780000 3300000 1350000>;
		qcom,cam-vreg-max-voltage = <1950000 3600000 1350000>;
		qcom,cam-vreg-op-mode = <105000 80000 105000>;
		qcom,gpio-no-mux = <0>;
		pinctrl-names = "cam_default", "cam_suspend";
		pinctrl-0 = <&cam_sensor_mclk1_active
				 &cam_sensor_rear2_active>;
		pinctrl-1 = <&cam_sensor_mclk1_suspend
				 &cam_sensor_rear2_suspend>;
		gpios = <&tlmm 33 0>,
			<&tlmm 46 0>,
			<&pm660l_gpios 3 0>,
			<&tlmm 35 0>,
			<&tlmm 0 0>;
		qcom,gpio-reset = <1>;
		qcom,gpio-vdig = <2>;
		qcom,gpio-vana = <3>;
		qcom,gpio-vaf = <4>;
		qcom,gpio-req-tbl-num = <0 1 2 3 4>;
		qcom,gpio-req-tbl-flags = <1 0 0 0 0>;
		qcom,gpio-req-tbl-label = "CAMIF_MCLK2",
					"CAM_RESET2",
					"CAM_VDIG",
					"CAM_VANA",
					"CAM_VAF";
		qcom,sensor-position = <2>;
		qcom,sensor-mode = <0>;
		qcom,cci-master = <1>;
		status = "ok";
		clocks = <&clock_mmss MCLK1_CLK_SRC>,
			<&clock_mmss MMSS_CAMSS_MCLK1_CLK>;
		clock-names = "cam_src_clk", "cam_clk";
		qcom,clock-rates = <24000000 0>;
	};
};

&spmi_bus {
	qcom,pm660@0 {
		pm660_charger: qcom,qpnp-smb2 {
			qcom,iterm-ma = <165>;
			qcom,batt_capacity_mah = <3150>;
			qcom,temp_little_cold_fastchg_current_ma_high = <1450>;	/*0.95*0.5C 1503.5~1567.5*/
			qcom,temp_little_cold_fastchg_current_ma_low = <850>;	/*0.95*0.3C 876.5~940.5*/
			qcom,temp_little_cold_fastchg_current_ma = <850>;		/* 0.15C = 495*/
			qcom,temp_cool_fastchg_current_ma_high = <2000>;			/* 0.25C = 825 */ /*0.95*0.7C 2130.5~2194.5*/
			qcom,temp_cool_fastchg_current_ma_low = <1450>;			/* 0.15C = 495 */ /*0.95*0.5C 1503.5~1567.5*/
			qcom,temp_warm_fastchg_current_ma = <850>;				/* 0.25C = 825 */ /*0.3C 876.5~940.5*/
			qcom,usbid-gpio = <&tlmm 49 0x00>;
			pinctrl-names = "usbid_active", "usbid_sleep";
			pinctrl-3 = <&usbid_active>;
			pinctrl-4 = <&usbid_sleep>;
		};
	};
};			
